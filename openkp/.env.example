# Copy this to .env and fill in your values. NEVER commit .env.
# Credentials are loaded by openkp.config.

# Kaiser Permanente username (kp.org login)
KP_USERNAME=

# Kaiser password. For better security, leave blank and store in macOS Keychain
# (the config loader falls back to keyring if this is empty).
KP_PASSWORD=

# Where to persist the logged-in browser profile and cookies. Defaults to ~/.openkp
OPENKP_DATA_DIR=

# Log level: DEBUG, INFO, WARNING, ERROR
OPENKP_LOG_LEVEL=INFO
