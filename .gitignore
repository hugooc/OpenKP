# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
*.swp
*~

# Claude Code local state (per-project settings, worktrees)
.claude/

# Secrets (belt-and-suspenders; package has its own .gitignore too)
.env
.env.local

# Research scratch space (never commit captured HAR files or PHI)
docs/research/captures/
docs/research/**/*.har
docs/research/**/*.json.phi

# Recon journals are dev artifacts that contain real account data.
# Live in private/documentation/recon/ (covered by the private/ rule below).
# Tracked journals were expunged from history via the 2026-05-10 PHI rewrite.
docs/recon/

# Private local project archive. Contains PHI, recon journals, screenshots,
# rewrite replacement tables, sample session data, and other non-publishable
# material. Anything you keep alongside the repo for your own use but should
# never ship publicly.
private/

# Python (in case anything leaks outside openkp/)
__pycache__/
*.py[cod]
.venv/
venv/

# Reference materials we don't want in git
openrecord/
openrecord-source/
reference/

# Local launcher (Hugo-specific)
Launch OpenKP.command
